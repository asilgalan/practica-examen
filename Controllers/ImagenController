using Microsoft.AspNetCore.Mvc;

[ApiController]
[Route("api/[controller]")]
public class ImagenController : ControllerBase
{
    private readonly IWebHostEnvironment _env;

    public ImagenController(IWebHostEnvironment env)
    {
        _env = env;
    }

    [HttpPost("subir")]
    public async Task<IActionResult> SubirImagen(IFormFile archivo)
    {
        if (archivo == null || archivo.Length == 0)
            return BadRequest("No se envió ningún archivo");

        // Ruta carpeta uploads
        string carpeta = Path.Combine(_env.WebRootPath, "uploads");

        if (!Directory.Exists(carpeta))
            Directory.CreateDirectory(carpeta);

        // Nombre único
        string nombreArchivo = Guid.NewGuid().ToString() + Path.GetExtension(archivo.FileName);

        string rutaCompleta = Path.Combine(carpeta, nombreArchivo);

        using (var stream = new FileStream(rutaCompleta, FileMode.Create))
        {
            await archivo.CopyToAsync(stream);
        }

        string url = $"{Request.Scheme}://{Request.Host}/uploads/{nombreArchivo}";

        return Ok(new { mensaje = "Imagen subida", url });
    }
}